
<%- include('partials/header') %>
    
    <!-- HERO SECTION -->
    <main class="hero-section">

        <div class="hero-content">

            <img src="/images/havensocial_logo.webp" alt="HavenSocial">

            <h1>
                
                <%= title %>

            </h1>
    
            <p class="hero-subtitle">

                Join the next-generation <strong>SocialFi</strong> platform.<br>
                Connect meaningfully, share your voice, build community,
                and earn <strong>HavenByte Token (HBT)</strong>.
            </p>
    
            <div class="cta-group">

                <a href="/register" class="btn-primary btn-large">Join HavenSocial Now</a>

                <a href="/login" class="btn-secondary btn-large">Log in</a>

            </div>

        </div>
    
        <div class="hero-visual">

            <img src="/images/havensocial_logo.webp" alt="HavenSocial in action" onerror="this.style.display='none'">
        </div>

    </main>
    
    <!-- FEATURES SECTION -->
    <section class="features">

        <h2>Why people love HavenSocial</h2>

        <div class="features-grid">

            <div class="feature-card">

                <span class="icon">🌐</span>

                <h3>Real Connections</h3>

                <p>Follow, engage, and discover without manipulative algorithms.</p>

            </div>

            <div class="feature-card">

                <span class="icon">💰</span>

                <h3>Earn Rewards</h3>

                <p>Get paid in HBT tokens for creating great content and growing your network.</p>
            </div>

            <div class="feature-card">

                <span class="icon">🔒</span>

                <h3>You Own It</h3>

                <p>Your content. Your audience. Your value.</p>

            </div>

        </div>

    </section>
    
    <!-- FINAL CTA -->
    <section class="final-cta">

        <h2>Be part of the future of social media</h2>

        <a href="/register" class="btn-primary btn-large">Create Your Account →</a>

    </section>
    
    <!-- X-STYLE FOOTER -->

    <div class="footer-links">

        <a href="#">About</a>

        <a href="#">Help Center</a>

        <a href="#">Terms of Service</a>

        <a href="#">Privacy Policy</a>

        <a href="#">Cookie Policy</a>

        <a href="#">Accessibility</a>

        <a href="#">Ads Info</a>

        <a href="#">Blog</a>

        <a href="#">Careers</a>

        <a href="#">Brand Resources</a>

        <a href="#">Marketing</a>

        <a href="#">Developers</a>

        <a href="#">Settings</a>

    </div>
    
    <%- include('partials/footer') %>

