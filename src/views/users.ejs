
<%- include('partials/header') %>

    <main class="admin-page">
        <div class="page-header">
            <h1>
                <%= title %>
            </h1>
            <p class="page-subtitle">Welcome, Founder. You have full control over user accounts.</p>

        </div>

        <div class="table-container">
            <table class="user-management-table" id="usersTable">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Verified</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user=> { %>
                        <tr data-username="<%= user.username.toLowerCase() %>"
                            data-email="<%= user.email.toLowerCase() %>"
                            data-name="<%= (user.full_name || '').toLowerCase() %>">
                            <td><strong>@<%= user.username %></strong></td>
                            <td>
                                <%= user.full_name || '—' %>
                            </td>
                            <td>
                                <%= user.email %>
                            </td>
                            <td><span class="role-badge <%= user.role_name.toLowerCase() %>">
                                    <%= user.role_name %>
                                </span></td>
                            <td class="status-cell">
                                <%= user.verified ? '✅ Verified' : '❌ Not verified' %>
                            </td>
                            <td class="status-cell">
                                <% if (user.suspended) { %>
                                    🚫 Suspended
                                    <% } else { %>
                                        <span class="active">Active</span>
                                        <% } %>
                            </td>
                            <td>
                                <%= new Date(user.created_at).toLocaleDateString('en-US', { year: 'numeric' ,
                                    month: 'short' , day: 'numeric' }) %>
                            </td>
                            <td class="actions-cell">
                                <form action="/users/<%= user.users_id %>/suspend" method="POST"
                                    style="display:inline;">
                                    <input type="hidden" name="action"
                                        value="<%= user.suspended ? 'unsuspend' : 'suspend' %>">
                                    <button type="submit"
                                        class="btn <%= user.suspended ? 'btn-success' : 'btn-warning' %> btn-small">
                                        <%= user.suspended ? 'Unsuspend' : 'Suspend' %>
                                    </button>
                                </form>

                                <form action="/users/<%= user.users_id %>/verify" method="POST" style="display:inline;">
                                    <input type="hidden" name="action"
                                        value="<%= user.verified ? 'unverify' : 'verify' %>">
                                    <button type="submit"
                                        class="btn <%= user.verified ? 'btn-secondary' : 'btn-primary' %> btn-small">
                                        <%= user.verified ? 'Remove Badge' : 'Verify' %>
                                    </button>
                                </form>

                                <form action="/users/<%= user.users_id %>/delete" method="POST" style="display:inline;"
                                    onsubmit="return confirm('Delete this user permanently? This action cannot be undone.');">
                                    <button type="submit" class="btn btn-danger btn-small">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </main>

    <%- include('partials/footer') %>