
<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Welcome, Founder. You have full control over user accounts.</p>

        <table class="user-management-table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Verified</th>
                    <th>Suspended</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user=> { %>
                    <tr>
                        <td>@<%= user.username %>
                        </td>
                        <td>
                            <%= user.full_name || '—' %>
                        </td>
                        <td>
                            <%= user.email %>
                        </td>
                        <td>
                            <%= user.role_name %>
                        </td>
                        <td>
                            <%= user.verified ? '✅' : '❌' %>
                        </td>
                        <td>
                            <%= user.suspended ? '🚫' : 'Active' %>
                        </td>
                        <td>
                            <%= new Date(user.created_at).toLocaleDateString() %>
                        </td>
                        <td>
                            <!-- Suspend / Unsuspend -->
                            <form action="/users/<%= user.users_id %>/suspend" method="POST" style="display:inline;">
                                <input type="hidden" name="action"
                                    value="<%= user.suspended ? 'unsuspend' : 'suspend' %>">
                                <button type="submit" class="btn <%= user.suspended ? 'btn-success' : 'btn-warning' %>">
                                    <%= user.suspended ? 'Unsuspend' : 'Suspend' %>
                                </button>
                            </form>

                            <!-- Verify -->
                            <form action="/users/<%= user.users_id %>/verify" method="POST" style="display:inline;">
                                <input type="hidden" name="action" value="<%= user.verified ? 'unverify' : 'verify' %>">
                                <button type="submit"
                                    class="btn <%= user.verified ? 'btn-secondary' : 'btn-primary' %>">
                                    <%= user.verified ? 'Remove Badge' : 'Verify' %>
                                </button>
                            </form>

                            <!-- Delete -->
                            <form action="/users/<%= user.users_id %>/delete" method="POST" style="display:inline;"
                                onsubmit="return confirm('Are you sure you want to delete this user?');">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </main>

    <%- include('partials/footer') %>