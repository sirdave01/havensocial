<%- include('partials/header') %>

    <main class="feed-page">

        <div class="compose-tweet">

            <form action="/tweets" method="POST" id="tweetForm">

                <textarea name="content" placeholder="What's happening?" maxlength="280" required></textarea>

                <button type="submit" class="btn-primary">Post</button>

            </form>

        </div>

        <div class="feed" id="feedContainer">

            <% if (feed && feed.length> 0) { %>
                <% feed.forEach(tweet=> { %>
                <%- include('partials/tweet-card', { tweet }) %>
                <% }); %>

            <% } else { %>
                
                <p class="empty-feed">No posts yet. Follow more people!</p>
                
            <% } %>
            
        </div>
        
    </main>

    <%- include('partials/footer') %>