<%- include('partials/header') %>

    <main class="tweet-detail-page container">
        <div class="back-bar">
            <a href="/feed" class="back-link">← Back</a>
        </div>

        <!-- Main Tweet -->
        <div class="main-tweet">
            <%- include('partials/tweet-card', { tweet }) %>
        </div>

        <hr>

        <!-- Reply Box (optional - you can make this a form later)
        <div class="reply-composer">
            <form action="/tweets/reply" method="POST">
                <input type="hidden" name="isReplyTo" value="<%= tweet.tweet_id %>">
                <textarea name="content" placeholder="Post your reply" maxlength="280" required></textarea>
                <button type="submit" class="btn-primary">Reply</button>
            </form>
        </div> -->

        <!-- Replies -->
        <div class="replies-section">
            
            <h3>Replies (<%= replies.length %>)</h3>

            <% if (replies && replies.length> 0) { %>
                <% replies.forEach(reply=> { %>
                    <%- include('partials/tweet-card', { tweet: reply }) %>
                <% }); %>
            <% } else { %>
                    <p class="no-replies">No replies yet. Be the first!</p>
            <% } %>

        </div>

    </main>

    <%- include('partials/footer') %>