<div class="tweet-card <%= tweet.is_deleted ? 'deleted' : '' %>" data-tweet-id="<%= tweet.tweet_id %>">

    <div class="tweet-header">
        <img src="<%= tweet.profile_picture_url || '/images/default-avatar.jpg' %>" class="tweet-avatar"
            onerror="this.onerror=null; this.src='/images/default-avatar.jpg'">

        <div class="tweet-user-info">
            <a href="/<%= tweet.username %>" class="user-link">
                <strong>
                    <%= tweet.display_name || tweet.username %>
                </strong>
            </a>
            <span>@<%= tweet.username %></span>
        </div>

        <% if (!tweet.is_deleted && tweet.user_id===user?.users_id) { %>
            <div class="tweet-owner-actions">
                <button class="menu-btn" data-tweet-id="<%= tweet.tweet_id %>" aria-label="More options">⋯</button>
                <div class="tweet-menu" data-menu-for="<%= tweet.tweet_id %>">
                    <button class="pin-btn" data-tweet-id="<%= tweet.tweet_id %>">📌 Pin</button>
                    <button class="edit-btn" data-tweet-id="<%= tweet.tweet_id %>">✏️ Edit</button>
                    <button class="delete-btn" data-tweet-id="<%= tweet.tweet_id %>">🗑 Delete</button>
                </div>
            </div>
            <% } %>
    </div>

    <div class="tweet-content">
        <p>
            <%= tweet.content %>
        </p>
    </div>

    <% const mediaItems = Array.isArray(tweet.media_url) ? tweet.media_url : (tweet.media_url ? [tweet.media_url] : []); %>
    <% if (mediaItems.length) { %>
        <div class="tweet-media">
            <% mediaItems.forEach(media => { %>
                <% const mediaPath = String(media || '').trim(); %>
                <% if (mediaPath.match(/\.(mp4|webm)$/i)) { %>
                    <video controls preload="metadata" class="tweet-media-item">
                        <source src="<%= mediaPath %>" type="video/mp4">
                    </video>
                <% } else { %>
                    <img src="<%= mediaPath %>" alt="Tweet media" class="tweet-media-item">
                <% } %>
            <% }); %>
        </div>
    <% } %>

    <div class="tweet-actions">

        <button class="action-btn reply-btn" data-tweet-id="<%= tweet.tweet_id %>"
            data-username="<%= tweet.username %>">
            💬 <span class="count">
                <%= tweet.reply_count || 0 %>
            </span>
        </button>

        <button class="action-btn like-btn <%= tweet.liked_by_user ? 'liked' : '' %>" data-tweet-id="<%= tweet.tweet_id %>">
            ❤️ <span class="count">
                <%= tweet.like_count || 0 %>
            </span>
        </button>

        <button class="action-btn repost-btn" data-tweet-id="<%= tweet.tweet_id %>">
            🔁 <span class="count">
                <%= tweet.retweet_count || 0 %>
            </span>
        </button>

        <span class="action-btn view-count" style="cursor: default;">
            👁 <span class="count">
                <%= tweet.view_count || 0 %>
            </span>
        </span>

        <button class="action-btn share-btn" data-tweet-id="<%= tweet.tweet_id %>" title="Share">
            🔗
        </button>
    </div>
</div>