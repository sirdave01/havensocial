<%- include('partials/header') %>

    <main class="profile-page">

        <div class="profile-header">

            <div class="profile-picture">
                <% if (profile.profile_picture_url) { %>
                    <img src="<%= profile.profile_picture_url %>" alt="Profile Picture" id="current-profile-img">
                    <% } else { %>
                        <div class="placeholder-avatar">👤</div>
                        <% } %>
            </div>

            <div class="profile-info">
                <h1>
                    <%= profile.display_name || profile.username %>
                </h1>
                <p class="username">@<%= profile.username %>
                </p>
                <% if (profile.verified) { %><span class="verified">✓ Verified</span>
                    <% } %>

                        <% if (profile.bio) { %>
                            <p class="bio">
                                <%= profile.bio %>
                            </p>
                            <% } %>

                                <div class="stats">
                                    <span><strong>
                                            <%= profile.follower_count || 0 %>
                                        </strong> Followers</span>
                                    <span><strong>
                                            <%= profile.following_count || 0 %>
                                        </strong> Following</span>
                                    <span><strong>
                                            <%= profile.post_count || 0 %>
                                        </strong> Tweets</span>
                                </div>
            </div>

            <% if (isOwner) { %>
                <button onclick="toggleEditForm()" class="btn-edit">Edit Profile</button>
                <% } %>
        </div>

        <!-- Edit Profile Form -->
        <% if (isOwner) { %>

            <div id="editForm" class="edit-profile-form" style="display: none;">
                
                <h2>Edit Profile</h2>
                <form action="/profile/update" method="POST" enctype="multipart/form-data">

                    <div class="form-group">

                        <label for="profilePictureInput">Profile Picture</label>
                    
                        <div id="dropzone" class="dropzone">

                            <div class="dropzone-content">

                                <span class="upload-icon">📸</span>

                                <p><strong>Click to upload</strong> or drag and drop</p>

                                <small>JPEG, PNG, GIF, WebP • Max 5MB</small>

                            </div>

                            <input type="file" name="profilePicture" id="profilePictureInput"
                                accept="image/jpeg,image/png,image/gif,image/webp" style="display: none;">

                        </div>

                    </div>

                        <div id="image-preview-container" style="margin-top: 16px;">
                            <img id="profile-preview" 
                            <% if (profile.profile_picture_url) { %>
                                src="<%= profile.profile_picture_url %>"
                            <% } else { %>
                                style="display: none;"
                            <% } %>
                            style="max-width: 100%; height: auto; border-radius: 12px; box-shadow: 0 4px 12px var(--shadow);"
                            alt="Profile Picture">

                            <button type="button" id="remove-photo-btn" class="btn-remove">
                                Remove Photo
                            </button>

                            <input type="hidden" name="removeProfilePicture" id="removeProfilePicture" value="false">

                        </div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="fullName" value="<%= profile.full_name || '' %>">
                    </div>

                    <div class="form-group">
                        <label>Display Name</label>
                        <input type="text" name="displayName" value="<%= profile.display_name || '' %>">
                    </div>

                    <div class="form-group">
                        <label>Bio</label>
                        <textarea name="bio" rows="5"><%= profile.bio || '' %></textarea>
                    </div>

                    <button type="submit" class="btn-primary">Save Changes</button>
                </form>
            </div>
            <% } %>

        <!-- User's Posts -->
        <% if (userTweets && userTweets.length> 0) { %>
            <div class="user-posts-section">
                <h2>Posts by <%= profile.display_name || profile.username %>
                </h2>
                <div class="feed">
                    <% userTweets.forEach(tweet=> { %>
                    <%- include('partials/tweet-card', { tweet }) %>
        <% }); %>
                </div>
            </div>
            <% } else { %>
                <p class="no-posts">No posts yet.</p>
            <% } %>
    </main>

    <%- include('partials/footer') %>