<%- include('partials/header') %>

    <main class="profile-page">
        <div class="profile-header">
            <div class="profile-picture">
                <% if (profile.profile_picture_url) { %>
                    <img src="<%= profile.profile_picture_url %>" alt="Profile Picture" id="current-profile-img">
                    <% } else { %>
                        <div class="placeholder-avatar">👤</div>
                        <% } %>
            </div>

            <div class="profile-info">
                <h1>
                    <%= profile.display_name || profile.username %>
                </h1>
                <p class="username">@<%= profile.username %>
                </p>
                <% if (profile.verified) { %><span class="verified">✓ Verified</span>
                    <% } %>

                        <% if (profile.bio) { %>
                            <p class="bio">
                                <%= profile.bio %>
                            </p>
                            <% } %>

                                <div class="stats">
                                    <span><strong>
                                            <%= profile.follower_count || 0 %>
                                        </strong> Followers</span>
                                    <span><strong>
                                            <%= profile.following_count || 0 %>
                                        </strong> Following</span>
                                    <span><strong>
                                            <%= profile.post_count || 0 %>
                                        </strong> Posts</span>
                                </div>
            </div>

            <% if (isOwner) { %>
                <button onclick="toggleEditForm()" class="btn-edit">Edit Profile</button>
                <% } %>
        </div>

        <!-- Edit Profile Form -->
        <% if (isOwner) { %>
            <div id="editForm" class="edit-profile-form" style="display: none;">
                <h2>Edit Profile</h2>
                <form action="/profile/update" method="POST" enctype="multipart/form-data">

                    <div class="form-group">
                        <label>Profile Picture</label>
                        <input type="file" name="profilePicture" id="profilePictureInput" accept="image/*">
                        <img id="profile-preview"
                            style="display:none; max-width: 250px; margin-top: 10px; border-radius: 8px;">
                    </div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="fullName" value="<%= profile.full_name || '' %>">
                    </div>

                    <div class="form-group">
                        <label>Display Name</label>
                        <input type="text" name="displayName" value="<%= profile.display_name || '' %>">
                    </div>

                    <div class="form-group">
                        <label>Bio</label>
                        <textarea name="bio" rows="5"><%= profile.bio || '' %></textarea>
                    </div>

                    <button type="submit" class="btn-primary">Save Changes</button>
                </form>
            </div>
            <% } %>
    </main>

    <%- include('partials/footer') %>